# Binaries
egress-proxy
proxy
!internal/proxy
main
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out
coverage.txt
coverage.html

# Dependency directories
vendor/

# Go workspace file
go.work

# IDE specific files
.vscode/
.idea/
*.swp
*.swo
*~

# OS specific files
.DS_Store
Thumbs.db

# Temporary files
tmp/
*.tmp

# Build artifacts
dist/
build/

e2e/server.crt
e2e/server.key
